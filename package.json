{
  "name": "neurocle",
  "private": true,
  "version": "0.1.0",
  "description": "A drawing canvas app built with React, Konva, and Electron.",
  "author": "pixelscope",
  "type": "module",
  "main": "dist-electron/electron/main.js",
  "scripts": {
    "dev:web": "vite",
    "dev:electron": "wait-on http://localhost:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "dev": "concurrently -k \"npm:dev:web\" \"npm:dev:electron\"",
    "build:web": "vite build",
    "build:electron": "rm -rf dist-electron node_modules/.tmp/tsconfig.electron.tsbuildinfo && tsc -p tsconfig.electron.json",
    "build": "tsc -b && npm run build:web && npm run build:electron",
    "dist": "rm -rf release && npm run build && electron-builder --mac dmg zip",
    "lint": "eslint .",
    "preview": "vite preview"
  },
  "build": {
    "appId": "com.pixelscope.neurocle",
    "productName": "Neurocle",
    "asar": true,
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "directories": {
      "output": "release"
    },
    "mac": {
      "category": "public.app-category.graphics-design",
      "target": [
        "dmg",
        "zip"
      ]
    }
  },
  "dependencies": {
    "idb-keyval": "^6.2.2",
    "konva": "^9.3.20",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-konva": "^19.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.0",
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.2",
    "@types/react-dom": "^19.1.2",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "cross-env": "^7.0.3",
    "electron": "^35.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9.25.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.30.1",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  }
}
